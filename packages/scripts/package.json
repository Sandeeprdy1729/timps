{
  "name": "@timps/scripts",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "timps start",
    "dev:watch": "timps start --watch",
    "dev:debug": "timps start --debug",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "typecheck": "echo 'no TypeScript sources in scripts package'",
    "format": "prettier --write src/**/*.ts",
    "build": "echo 'no build step for scripts package'",
    "build:watch": "tsc --watch",
    "clean": "rm -rf dist coverage",
    "clean:all": "rm -rf dist coverage node_modules",
    "start": "node dist/index.js",
    "start:prod": "NODE_ENV=production node dist/index.js",
    "install:all": "npm install && npm WORKSPACE install",
    "update:all": "npm update && npm WORKSPACE update",
    "release": "standard-version",
    "release:major": "npm run release -- --release-as major",
    "release:minor": "npm run release -- --release-as minor",
    "release:patch": "npm run release -- --release-as patch",
    "docs": "docusaurus start",
    "docs:build": "docusaurus build",
    "docs:deploy": "docusaurus deploy",
    "benchmark": "node benches/run.js",
    "docker:build": "docker build -t timps:latest .",
    "docker:run": "docker run -p 3000:3000 timps:latest",
    "docker:compose": "docker-compose up",
    "docker:compose:build": "docker-compose build",
    "docker:stop": "docker-compose down",
    "docker:clean": "docker system prune -af",
    "prebuild": "npm run typecheck",
    "pretest": "npm run typecheck",
    "predev": "npm run typecheck",
    "postinstall": "npm run build",
    "prepare": "npm run typecheck && (husky install || true)",
    "precommit": "npm run lint && npm run test"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "eslint": "^8.55.0",
    "husky": "^8.0.3",
    "prettier": "^3.1.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "workspaces": [
    "packages/*"
  ]
}
