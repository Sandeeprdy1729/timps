{
  "name": "@timps/memory-dashboard",
  "version": "0.1.0",
  "description": "TIMPS web memory dashboard — interactive sigma.js knowledge graph visualizing your AI agent's 9-layer persistent memory.",
  "private": true,
  "author": "TIMPS Contributors",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:ui\"",
    "dev:api": "tsx watch src/api/server.ts",
    "dev:ui": "vite",
    "build": "tsc --noEmit && vite build",
    "build:api": "tsc -p tsconfig.api.json",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@timps-ai/memory-core": "*",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "sigma": "^3.0.0",
    "graphology": "^0.25.4",
    "graphology-layout": "^0.6.1",
    "graphology-layout-forceatlas2": "^0.10.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "tsx": "^4.19.3",
    "typescript": "^5.5.0",
    "vite": "^6.3.5"
  }
}
