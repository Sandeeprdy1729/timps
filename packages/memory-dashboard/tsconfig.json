{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noEmit": true,
    "skipLibCheck": true,
    "paths": {
      "@timps-ai/memory-core": ["../../packages/memory-core/src/index.ts"]
    }
  },
  "include": ["src"]
}
