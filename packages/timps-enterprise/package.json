{
  "name": "@timps/enterprise",
  "version": "0.1.0",
  "description": "Enterprise team memory server for TIMPS — shared persistent memory with JWT authentication, multi-user support, and role-based access for AI coding teams.",
  "type": "module",
  "main": "./dist/server.js",
  "files": ["dist/", "README.md", "LICENSE"],
  "scripts": {
    "dev": "tsx src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "NODE_ENV=test TIMPS_JWT_SECRET=test-secret tsx test/auth.test.ts && tsx test/teamMemory.test.ts && tsx test/server.test.ts"
  },
  "dependencies": {
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "uuid": "^9.0.0",
    "@timps/memory-core": "*"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/uuid": "^9.0.7",
    "@types/node": "^22.0.0",
    "@types/jest": "^29.5.0",
    "@types/supertest": "^6.0.0",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  },
  "engines": { "node": ">=18" },
  "author": "TIMPS Contributors",
  "repository": {
    "type": "git",
    "url": "https://github.com/Sandeeprdy1729/timps"
  },
  "license": "MIT"
}
