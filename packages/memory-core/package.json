{
  "name": "@timps/memory-core",
  "version": "1.0.0",
  "description": "TIMPS 9-layer persistent memory engine — working, episodic, semantic, procedural, and 5 forge layers with 17 intelligence tools for AI agents. Contradiction detection, bug pattern tracking, and burnout monitoring.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.js"
    },
    "./safety/*": {
      "types": "./src/safety/*.ts",
      "import": "./src/safety/*.ts"
    },
    "./sandbox/*": {
      "types": "./src/sandbox/*.ts",
      "import": "./src/sandbox/*.ts"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "require": "./dist/server/index.js"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "require": "./dist/client/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/server/index.ts src/client/index.ts --format cjs --dts --out-dir dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "minisearch": "^7.1.0",
    "express": "^4.21.0",
    "cors": "^2.8.5",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/express": "^5.0.0",
    "@types/cors": "^2.8.17",
    "@types/ws": "^8.5.13",
    "@types/react-native": "^0.73.0",
    "tsup": "^8.5.0",
    "typescript": "^5.6.0",
    "vitest": "^3.2.6"
  },
  "keywords": [
    "memory",
    "agent",
    "ai",
    "timps",
    "episodic",
    "semantic",
    "working-memory"
  ],
  "author": "TIMPS Contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Sandeeprdy1729/timps"
  },
  "homepage": "https://timps.ai",
  "bugs": {
    "url": "https://github.com/Sandeeprdy1729/timps/issues"
  },
  "publishConfig": {
    "access": "public"
  }
}
