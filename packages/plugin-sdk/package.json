{
  "name": "@timps-ai/plugin-sdk",
  "version": "0.1.1",
  "description": "TIMPS plugin SDK — formal interface for extending TIMPS agents with custom commands, tools, and lifecycle hooks. Build plugins for AI coding workflows.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs --dts --out-dir dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.5.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.9"
  },
  "keywords": [
    "timps",
    "plugin",
    "agent",
    "sdk",
    "extensibility"
  ],
  "author": "TIMPS Contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Sandeeprdy1729/timps"
  },
  "homepage": "https://github.com/Sandeeprdy1729/timps/tree/main/packages/plugin-sdk",
  "bugs": {
    "url": "https://github.com/Sandeeprdy1729/timps/issues"
  },
  "publishConfig": {
    "access": "public"
  }
}
