{
  "name": "@timps-ai/timps-sdk",
  "version": "1.0.0",
  "description": "TIMPS SDK — lightweight memory for AI agents. Store and recall semantic memories with zero config.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "sideEffects": false,
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --out-dir dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "@timps-ai/memory-core": ">=1.0.0"
  },
  "peerDependenciesMeta": {
    "@timps-ai/memory-core": {
      "optional": true
    }
  },
  "devDependencies": {
    "@timps-ai/memory-core": "*",
    "@types/node": "^22.0.0",
    "tsup": "^8.5.0",
    "typescript": "^5.6.0",
    "vitest": "^3.2.6"
  },
  "keywords": [
    "timps",
    "memory",
    "sdk",
    "ai",
    "agent",
    "embeddings",
    "semantic"
  ],
  "author": "TIMPS Contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Sandeeprdy1729/timps"
  },
  "homepage": "https://timps.ai",
  "bugs": {
    "url": "https://github.com/Sandeeprdy1729/timps/issues"
  },
  "publishConfig": {
    "access": "public"
  }
}
