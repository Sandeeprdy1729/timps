{
  "name": "timps-ai-coding-agent",
  "displayName": "TIMPS \u2014 AI Coding Agent",
  "description": "AI coding agent powered by TIMPS-Coder (local Ollama) or OpenAI / Gemini",
  "version": "1.2.0",
  "publisher": "TIMPs",
  "icon": "logo.png",
  "engines": {
    "vscode": "^1.115.0"
  },
  "categories": [
    "AI",
    "Chat",
    "Other"
  ],
  "keywords": [
    "ai",
    "coding",
    "assistant",
    "timps",
    "ollama",
    "llm",
    "persistent-memory",
    "claude-code-alternative",
    "local-llm",
    "ai-agent",
    "mcp"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "timps-sidebar",
          "title": "TIMPS AI",
          "icon": "resources/timps-icon.svg"
        }
      ]
    },
    "views": {
      "timps-sidebar": [
        {
          "type": "webview",
          "id": "timps.chatView",
          "name": "TIMPS Chat",
          "icon": "resources/timps-icon.svg",
          "contextualTitle": "TIMPS AI Coding Agent"
        },
        {
          "type": "webview",
          "id": "timps.nexusForgeExplorer",
          "name": "Memory Explorer",
          "contextualTitle": "Project Memory Graph"
        }
      ]
    },
    "commands": [
      {
        "command": "timps.openChat",
        "title": "Open TIMPS Chat",
        "category": "TIMPS",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "timps.newSession",
        "title": "New Session",
        "category": "TIMPS",
        "icon": "$(add)"
      },
      {
        "command": "timps.clearHistory",
        "title": "Clear Chat History",
        "category": "TIMPS",
        "icon": "$(trash)"
      },
      {
        "command": "timps.openSettings",
        "title": "TIMPS Settings",
        "category": "TIMPS",
        "icon": "$(settings-gear)"
      },
      {
        "command": "timps.askAboutSelection",
        "title": "Ask TIMPS about Selection",
        "category": "TIMPS"
      },
      {
        "command": "timps.explainCode",
        "title": "Explain with TIMPS",
        "category": "TIMPS"
      },
      {
        "command": "timps.fixCode",
        "title": "Fix with TIMPS",
        "category": "TIMPS"
      },
      {
        "command": "timps.generateTests",
        "title": "Generate Tests with TIMPS",
        "category": "TIMPS"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "timps.askAboutSelection",
          "when": "editorHasSelection",
          "group": "timps@1"
        },
        {
          "command": "timps.explainCode",
          "when": "editorHasSelection",
          "group": "timps@2"
        },
        {
          "command": "timps.fixCode",
          "when": "editorHasSelection",
          "group": "timps@3"
        },
        {
          "command": "timps.generateTests",
          "when": "editorHasSelection",
          "group": "timps@4"
        }
      ],
      "view/title": [
        {
          "command": "timps.newSession",
          "when": "view == timps.chatView",
          "group": "navigation@1"
        },
        {
          "command": "timps.clearHistory",
          "when": "view == timps.chatView",
          "group": "navigation@2"
        },
        {
          "command": "timps.openSettings",
          "when": "view == timps.chatView",
          "group": "navigation@3"
        }
      ]
    },
    "keybindings": [
      {
        "command": "timps.openChat",
        "key": "ctrl+shift+t",
        "mac": "cmd+shift+t"
      },
      {
        "command": "timps.askAboutSelection",
        "key": "ctrl+shift+a",
        "mac": "cmd+shift+a",
        "when": "editorHasSelection"
      }
    ],
    "configuration": {
      "title": "TIMPS AI Coding Agent",
      "properties": {
        "timps.provider": {
          "type": "string",
          "enum": [
            "ollama",
            "openai",
            "gemini"
          ],
          "default": "ollama",
          "description": "AI provider to use"
        },
        "timps.model": {
          "type": "string",
          "default": "sandeeprdy1729/timps-coder",
          "description": "Model name (Ollama) or model ID (OpenAI/Gemini)"
        },
        "timps.ollamaUrl": {
          "type": "string",
          "default": "http://localhost:11434",
          "description": "Ollama server URL"
        },
        "timps.openaiApiKey": {
          "type": "string",
          "default": "",
          "description": "OpenAI API key (if using OpenAI provider)"
        },
        "timps.geminiApiKey": {
          "type": "string",
          "default": "",
          "description": "Google Gemini API key (if using Gemini provider)"
        },
        "timps.maxTokens": {
          "type": "number",
          "default": 4096,
          "description": "Max tokens per response"
        },
        "timps.temperature": {
          "type": "number",
          "default": 0.2,
          "minimum": 0,
          "maximum": 2,
          "description": "Model temperature (0 = deterministic, 2 = creative)"
        },
        "timps.systemPrompt": {
          "type": "string",
          "default": "You are TIMPS-Coder, an expert AI coding assistant built by Sandeep Reddy (TIMPS). You help with coding, debugging, architecture, and explanations. Be concise, accurate, and practical.",
          "description": "System prompt sent with every request"
        },
        "timps.autoContext": {
          "type": "boolean",
          "default": true,
          "description": "Automatically include the current file as context"
        },
        "timps.theme": {
          "type": "string",
          "enum": [
            "timps-dark",
            "timps-light"
          ],
          "default": "timps-dark",
          "description": "Chat panel theme"
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "npm run compile",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/vscode": "^1.115.0",
    "@vscode/vsce": "^2.32.0",
    "typescript": "^5.9.3"
  }
}