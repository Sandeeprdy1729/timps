{
  "name": "timps-ai-coding-agent",
  "displayName": "TIMPS — AI Coding Agent with Persistent Memory",
  "description": "22-layer persistent memory system that gives your AI coding agent perfect recall. Inline memory panel, memory-aware autocomplete, contradiction detection, and project-wide context across sessions.",
  "version": "1.3.0",
  "publisher": "TIMPs",
  "repository": {
    "type": "git",
    "url": "https://github.com/Sandeeprdy1729/timps"
  },
  "icon": "logo.png",
  "engines": {
    "vscode": "^1.115.0"
  },
  "categories": [
    "AI",
    "Chat",
    "Programming Languages",
    "Machine Learning",
    "Visualization"
  ],
  "keywords": [
    "ai",
    "coding",
    "assistant",
    "timps",
    "ollama",
    "llm",
    "memory",
    "persistent-memory",
    "claude-code-alternative",
    "local-llm",
    "ai-agent",
    "mcp",
    "autocomplete",
    "code-memory",
    "developer-tools"
  ],
  "main": "./out/extension.js",
  "activationEvents": [
    "onLanguage:typescript",
    "onLanguage:javascript",
    "onLanguage:python",
    "onLanguage:rust",
    "onLanguage:go",
    "onLanguage:java",
    "onLanguage:csharp",
    "onLanguage:cpp",
    "onLanguage:ruby",
    "onCommand:timps.openChat",
    "onCommand:timps.recall",
    "onCommand:timps.showMemoryPanel",
    "onCommand:timps.checkContradictions",
    "onCommand:timps.toggleAutocomplete",
    "onCommand:timps.toggleWatcher",
    "onCommand:timps.toggleLsp",
    "onView:timps.memoryPanel"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "timps-sidebar",
          "title": "TIMPS AI",
          "icon": "resources/timps-icon.svg"
        }
      ]
    },
    "views": {
      "timps-sidebar": [
        {
          "type": "webview",
          "id": "timps.chatView",
          "name": "TIMPS Chat",
          "icon": "resources/timps-icon.svg",
          "contextualTitle": "TIMPS AI Coding Agent"
        },
        {
          "type": "webview",
          "id": "timps.memoryPanel",
          "name": "Memory Context",
          "icon": "resources/memory-icon.svg",
          "contextualTitle": "TIMPS Memory Context"
        },
        {
          "type": "webview",
          "id": "timps.nexusForgeExplorer",
          "name": "Memory Explorer",
          "contextualTitle": "Project Memory Graph"
        },
        {
          "type": "tree",
          "id": "timps.memoryView",
          "name": "Memory Layers",
          "contextualTitle": "TIMPS 3-Layer Memory"
        }
      ]
    },
    "commands": [
      {
        "command": "timps.refreshMemory",
        "title": "Refresh Memory",
        "category": "TIMPS",
        "icon": "$(refresh)"
      },
      {
        "command": "timps.openChat",
        "title": "Open TIMPS Chat",
        "category": "TIMPS",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "timps.newSession",
        "title": "New Session",
        "category": "TIMPS",
        "icon": "$(add)"
      },
      {
        "command": "timps.clearHistory",
        "title": "Clear Chat History",
        "category": "TIMPS",
        "icon": "$(trash)"
      },
      {
        "command": "timps.openSettings",
        "title": "TIMPS Settings",
        "category": "TIMPS",
        "icon": "$(settings-gear)"
      },
      {
        "command": "timps.askAboutSelection",
        "title": "Ask TIMPS about Selection",
        "category": "TIMPS"
      },
      {
        "command": "timps.explainCode",
        "title": "Explain with TIMPS",
        "category": "TIMPS"
      },
      {
        "command": "timps.fixCode",
        "title": "Fix with TIMPS",
        "category": "TIMPS"
      },
      {
        "command": "timps.generateTests",
        "title": "Generate Tests with TIMPS",
        "category": "TIMPS"
      },
      {
        "command": "timps.recall",
        "title": "Recall Memories…",
        "category": "TIMPS",
        "icon": "$(search)"
      },
      {
        "command": "timps.showMemoryPanel",
        "title": "Show Memory Panel",
        "category": "TIMPS",
        "icon": "$(layers)"
      },
      {
        "command": "timps.checkContradictions",
        "title": "Check for Contradictions",
        "category": "TIMPS",
        "icon": "$(warning)"
      },
      {
        "command": "timps.toggleAutocomplete",
        "title": "Toggle Memory Autocomplete",
        "category": "TIMPS"
      },
      {
        "command": "timps.toggleWatcher",
        "title": "Toggle Edit Watcher",
        "category": "TIMPS"
      },
      {
        "command": "timps.toggleContradictionCheck",
        "title": "Toggle Contradiction Checking",
        "category": "TIMPS"
      },
      {
        "command": "timps.memoryStats",
        "title": "Show Memory Statistics",
        "category": "TIMPS",
        "icon": "$(graph)"
      },
      {
        "command": "timps.toggleLsp",
        "title": "Toggle LSP Integration",
        "category": "TIMPS"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "timps.askAboutSelection",
          "when": "editorHasSelection",
          "group": "timps@1"
        },
        {
          "command": "timps.explainCode",
          "when": "editorHasSelection",
          "group": "timps@2"
        },
        {
          "command": "timps.fixCode",
          "when": "editorHasSelection",
          "group": "timps@3"
        },
        {
          "command": "timps.generateTests",
          "when": "editorHasSelection",
          "group": "timps@4"
        },
        {
          "command": "timps.recall",
          "when": "editorHasSelection",
          "group": "timps@5"
        }
      ],
      "view/title": [
        {
          "command": "timps.newSession",
          "when": "view == timps.chatView",
          "group": "navigation@1"
        },
        {
          "command": "timps.clearHistory",
          "when": "view == timps.chatView",
          "group": "navigation@2"
        },
        {
          "command": "timps.openSettings",
          "when": "view == timps.chatView",
          "group": "navigation@3"
        },
        {
          "command": "timps.refreshMemory",
          "when": "view == timps.memoryView",
          "group": "navigation@1"
        },
        {
          "command": "timps.recall",
          "when": "view == timps.memoryPanel",
          "group": "navigation@1"
        },
        {
          "command": "timps.memoryStats",
          "when": "view == timps.memoryPanel",
          "group": "navigation@2"
        }
      ]
    },
    "keybindings": [
      {
        "command": "timps.openChat",
        "key": "ctrl+shift+t",
        "mac": "cmd+shift+t"
      },
      {
        "command": "timps.askAboutSelection",
        "key": "ctrl+shift+a",
        "mac": "cmd+shift+a",
        "when": "editorHasSelection"
      },
      {
        "command": "timps.recall",
        "key": "ctrl+shift+r",
        "mac": "cmd+shift+r"
      },
      {
        "command": "timps.showMemoryPanel",
        "key": "ctrl+shift+m",
        "mac": "cmd+shift+m"
      }
    ],
    "configuration": {
      "title": "TIMPS AI Coding Agent",
      "properties": {
        "timps.provider": {
          "type": "string",
          "enum": ["ollama", "openai", "gemini"],
          "default": "ollama",
          "description": "AI provider to use"
        },
        "timps.model": {
          "type": "string",
          "default": "sandeeprdy1729/timps-coder",
          "description": "Model name (Ollama) or model ID (OpenAI/Gemini)"
        },
        "timps.ollamaUrl": {
          "type": "string",
          "default": "http://localhost:11434",
          "description": "Ollama server URL"
        },
        "timps.openaiApiKey": {
          "type": "string",
          "default": "",
          "description": "OpenAI API key (if using OpenAI provider)"
        },
        "timps.geminiApiKey": {
          "type": "string",
          "default": "",
          "description": "Google Gemini API key (if using Gemini provider)"
        },
        "timps.maxTokens": {
          "type": "number",
          "default": 4096,
          "description": "Max tokens per response"
        },
        "timps.temperature": {
          "type": "number",
          "default": 0.2,
          "minimum": 0,
          "maximum": 2,
          "description": "Model temperature (0 = deterministic, 2 = creative)"
        },
        "timps.systemPrompt": {
          "type": "string",
          "default": "You are TIMPS-Coder, an expert AI coding assistant built by Sandeep Reddy (TIMPS). You help with coding, debugging, architecture, and explanations. Be concise, accurate, and practical.",
          "description": "System prompt sent with every request"
        },
        "timps.autoContext": {
          "type": "boolean",
          "default": true,
          "description": "Automatically include the current file as context"
        },
        "timps.theme": {
          "type": "string",
          "enum": ["timps-dark", "timps-light"],
          "default": "timps-dark",
          "description": "Chat panel theme"
        },
        "timps.serverUrl": {
          "type": "string",
          "default": "http://localhost:4100",
          "description": "TIMPS server URL (the MemoryServer)"
        },
        "timps.token": {
          "type": "string",
          "default": "",
          "description": "API token for TIMPS MemoryServer (leave empty for local development)"
        },
        "timps.enableAutocomplete": {
          "type": "boolean",
          "default": true,
          "description": "Enable memory-aware autocomplete suggestions"
        },
        "timps.enableWatcher": {
          "type": "boolean",
          "default": true,
          "description": "Automatically record file edits as memory episodes"
        },
        "timps.enableContradictionCheck": {
          "type": "boolean",
          "default": true,
          "description": "Check code changes for contradictions against stored memories"
        },
        "timps.autocompleteDebounceMs": {
          "type": "number",
          "default": 300,
          "minimum": 100,
          "maximum": 2000,
          "description": "Debounce delay for autocomplete (ms)"
        },
        "timps.contextUpdateDebounceMs": {
          "type": "number",
          "default": 500,
          "minimum": 100,
          "maximum": 5000,
          "description": "Debounce delay for memory panel context updates (ms)"
        },
        "timps.lsp.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable TIMPS LSP integration (definition enrichment, hover memories, contradiction diagnostics, bug pattern detection)"
        },
        "timps.lsp.debounceMs": {
          "type": "number",
          "default": 2000,
          "minimum": 500,
          "maximum": 10000,
          "description": "Debounce delay for LSP contradiction checking (ms)"
        },
        "timps.lsp.contradictionSeverity": {
          "type": "string",
          "enum": ["error", "warning", "information"],
          "default": "warning",
          "description": "Severity level for contradiction diagnostics"
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "npm run compile",
    "package": "vsce package",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "@types/vscode": "^1.125.0",
    "@vscode/vsce": "^3.9.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "tmp": "0.2.6"
  }
}
