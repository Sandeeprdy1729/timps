  },
  "homepage": "https://timps.ai",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "diff": "^5.2.0",
    "dotenv": "^17.4.2",
    "glob": "^10.4.0",
    "ora": "^8.1.0"
  },
  "devDependencies": {
    "@types/diff": "^5.2.0",
