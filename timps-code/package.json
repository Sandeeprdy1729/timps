{
  "name": "timps-code",
  "version": "2.0.0",
  "description": "Open-source CLI coding agent with 3-layer persistent memory. Free with Ollama. Drop-in Claude Code alternative. Works with any model.",
  "type": "module",
  "bin": {
    "timps": "./dist/bin/timps.js"
  },
  "main": "./dist/bin/timps.js",
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/bin/timps.ts",
    "start": "node dist/bin/timps.js",
    "prepublishOnly": "npm run build",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "ai",
    "coding-agent",
    "cli",
    "claude-code-alternative",
    "claude-code",
    "claude",
    "openai",
    "gemini",
    "ollama",
    "local-llm",
    "deepseek",
    "persistent-memory",
    "mcp",
    "model-context-protocol",
    "skills",
    "typescript",
    "open-source",
    "ai-agent",
    "code-generation",
    "developer-tools",
    "agentic",
    "autonomous-agent",
    "self-correcting",
    "free-ai",
    "swe-bench"
  ],
  "author": "TIMPS Contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Sandeeprdy1729/timps"
  },
  "homepage": "https://timps.ai",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "diff": "^5.2.0",
    "dotenv": "^17.4.2",
    "glob": "^10.4.0",
    "ora": "^9.4.0"
  },
  "devDependencies": {
    "@types/diff": "^5.2.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.14",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
