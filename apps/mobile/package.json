    "react-native-safe-area-context": "4.8.2",
    "react-native-screens": "3.29.0",
    "expo-linear-gradient": "~12.7.0",
    "expo-status-bar": "~1.11.1",
    "expo-speech": "~11.7.0",
    "@expo/vector-icons": "^14.0.0",
    "expo-local-authentication": "~13.8.0",
    "date-fns": "^3.3.1"
  },
  "devDependencies": {
    "@babel/core": "^7.23.0",
    "typescript": "^5.3.3",
    "@types/react": "^18.2.48"
