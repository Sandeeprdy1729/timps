# TIMPS Server — Full Configuration
# Copy to .env and fill in the values you need.
# Ollama is the default provider and needs NO API key.
# You only need keys for providers you actually use.

# ── Server ────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── PostgreSQL ────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=sandeep_ai
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# ── Qdrant Vector DB (required for memory features) ───────
QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=        # only needed if using Qdrant Cloud

# ── Model Provider ────────────────────────────────────────
# Options: ollama | openai | anthropic | gemini | openrouter
DEFAULT_MODEL_PROVIDER=ollama

# ── Ollama (free, local — recommended) ────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=qwen2.5-coder:7b

# ── Anthropic (Claude) ────────────────────────────────────
# ANTHROPIC_API_KEY=

# ── OpenAI ────────────────────────────────────────────────
# OPENAI_API_KEY=
# OPENAI_DEFAULT_MODEL=gpt-4o-mini

# ── Google Gemini ─────────────────────────────────────────
# GEMINI_API_KEY=
# GEMINI_DEFAULT_MODEL=gemini-2.0-flash

# ── OpenRouter (access 200+ models with one key) ──────────
# OPENROUTER_API_KEY=
# OPENROUTER_DEFAULT_MODEL=anthropic/claude-3.5-haiku

# ── Embeddings ────────────────────────────────────────────
# Ollama embeddings are free and work offline.
# Switch to openai for higher quality at a cost.
EMBEDDINGS_PROVIDER=ollama
EMBEDDINGS_MODEL=nomic-embed-text
EMBEDDINGS_DIMENSION=768

# ── Memory Tuning (optional) ──────────────────────────────
SHORT_TERM_TOKEN_LIMIT=4000
SHORT_TERM_MAX_MESSAGES=20
LONG_TERM_TOP_RESULTS=5
