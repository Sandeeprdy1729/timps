# Server Configuration
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=sandeep_ai
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=sandeep_ai_memories

# Redis (optional)
REDIS_HOST=
REDIS_PORT=6379
REDIS_PASSWORD=

# Model Provider: openrouter | ollama | openai | gemini
DEFAULT_MODEL_PROVIDER=openrouter

# OpenRouter — paste your key from openrouter.ai
OPENROUTER_API_KEY=sk-or-v1-your-key-here
# Any model from openrouter.ai/models — good starting picks:
#   anthropic/claude-3.5-haiku     fast + smart
#   google/gemini-2.0-flash-001    free tier available
#   meta-llama/llama-3.1-8b-instruct  free
OPENROUTER_DEFAULT_MODEL=anthropic/claude-3.5-haiku

# OpenAI (leave blank if not using)
OPENAI_API_KEY=
OPENAI_DEFAULT_MODEL=gpt-4o

# Gemini (leave blank if not using)
GEMINI_API_KEY=enter-your-api-key
GEMINI_DEFAULT_MODEL=gemini-2.0-flash

# Ollama (local)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=llama3.1:8b

# Embeddings — keep on Ollama (OpenRouter has no embeddings API)
EMBEDDINGS_PROVIDER=ollama
EMBEDDINGS_MODEL=nomic-embed-text
EMBEDDINGS_DIMENSION=768

# Memory
SHORT_TERM_TOKEN_LIMIT=4000
SHORT_TERM_MAX_MESSAGES=20
LONG_TERM_TOP_RESULTS=5
REFLECTION_THRESHOLD=10