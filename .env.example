# ─────────────────────────────────────────────
# TIMPS Code — CLI environment variables
# Copy to .env and fill in what you need.
# You only need the keys for providers you use.
# Ollama needs NO keys — just run `ollama serve`.
# ─────────────────────────────────────────────

# ── AI Providers (set at least one, or use Ollama for free) ──

ANTHROPIC_API_KEY=           # Claude (claude-sonnet-4-5, etc.)
OPENAI_API_KEY=              # OpenAI (gpt-4o, etc.)
GEMINI_API_KEY=              # Google Gemini (free tier available)
OPENROUTER_API_KEY=          # OpenRouter (many models, pay per use)

# ── Ollama (local, free — recommended for getting started) ──

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=qwen2.5-coder:7b

# ── Full TIMPS Server (only needed for MCP features) ──
# Uncomment and fill if you're running `docker compose up -d`

# TIMPS_SERVER_URL=http://localhost:3000
# TIMPS_USER_ID=1

# ─────────────────────────────────────────────
# For the full sandeep-ai server configuration,
# see sandeep-ai/.env.example
# ─────────────────────────────────────────────
