# Server Configuration
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# PostgreSQL Configuration
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=sandeep_ai
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Qdrant Vector Database (Optional)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=sandeep_ai_memories

# Redis (Optional - for caching)
REDIS_HOST=
REDIS_PORT=6379
REDIS_PASSWORD=

# Model Provider Selection
DEFAULT_MODEL_PROVIDER=openai

# OpenAI Configuration
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_DEFAULT_MODEL=gpt-4-turbo-preview

# Gemini Configuration
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_DEFAULT_MODEL=gemini-pro

# Ollama Configuration (for local models)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=llama2

# Embeddings Configuration
EMBEDDINGS_PROVIDER=openai
EMBEDDINGS_MODEL=text-embedding-3-small
EMBEDDINGS_DIMENSION=1536

# Memory Configuration
SHORT_TERM_TOKEN_LIMIT=4000
SHORT_TERM_MAX_MESSAGES=20
LONG_TERM_TOP_RESULTS=5
REFLECTION_THRESHOLD=10

# NexusForge Configuration (sub-agent trinity for episodic memory)
ENABLE_NEXUSFORGE=true
TIMPS_SERVER_URL=http://localhost:3000

# AetherForge / ChronosVeil Configuration
ENABLE_AETHERFORGE=true
AETHERFORGE_MAX_TRAVERSE=8
AETHERFORGE_CONFIDENCE_THRESHOLD=0.65
AETHERFORGE_REFUSAL_THRESHOLD=0.15
AETHERFORGE_MAX_SUMMARY=500

# VeilForge Configuration (four-layer persistence + ontology-driven entity graph)
ENABLE_VEILFORGE=true
VEILFORGE_MAX_TRAVERSE=8
VEILFORGE_CONFIDENCE_THRESHOLD=0.65
VEILFORGE_REFUSAL_THRESHOLD=0.15
VEILFORGE_MAX_SUMMARY=500

# TemporaTree Configuration (temporal memory tree + gated consolidation)
ENABLE_TEMPORATREE=true
TEMPORATREE_BMM_THRESHOLD=0.55
TEMPORATREE_MAX_DEPTH=4
TEMPORATREE_POLICY_RATE=0.1

# BindWeave Configuration (binding weaver + cross-event induction)
ENABLE_BINDWEAVE=true
BINDWEAVE_INDUCTION_THRESHOLD=0.45
BINDWEAVE_MAX_DEGREE=6
BINDWEAVE_REFLECTION_DEPTH=3

# EchoForge Configuration (hierarchical abstraction + confidence-weighted retrieval)
ENABLE_ECHOFORGE=true
ECHOFORGE_MIN_CONFIDENCE=0.65
ECHOFORGE_MAX_DEPTH=4
ECHOFORGE_REFLECTION_DEPTH=3

# AetherWeft Configuration (AKL context trees + validity rivers)
ENABLE_AETHERWEFT=true
AETHERWEFT_MATURITY_THRESHOLD=0.6
AETHERWEFT_DECAY_RATE=0.02
AETHERWEFT_MAX_RIVER_DEPTH=5

# ApexSynapse Configuration (temporal entity graph + query-time resolution)
ENABLE_APEXSYNAPSE=true
APEXSYNAPSE_MAX_STEPS=8
APEXSYNAPSE_MIN_CONFIDENCE=0.6
APEXSYNAPSE_MAX_PROPAGATION=3

# QuaternaryForge Configuration (four-layer typed router + evidence gating)
ENABLE_QUATERNARYFORGE=true
QUATERNARYFORGE_WISDOM_THRESHOLD=0.65
QUATERNARYFORGE_MEMORY_DECAY=0.03
QUATERNARYFORGE_INTELLIGENCE_AGE=30
