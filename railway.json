{
  "$schema": "https://railway.app/project-schema.json",
  "name": "timps",
  "services": [
    {
      "name": "timps-backend",
      "directory": "packages/server",
      "healthball": "/api/health",
      "envars": [
        {
          "key": "NODE_ENV",
          "value": "production"
        },
        {
          "key": "PORT",
          "value": "3000"
        }
      ]
    }
  ],
  "plugins": [
    {
      "name": "postgresql",
      "id": "postgresql"
    }
  ]
}
