{
  "name": "timps",
  "version": "1.0.3",
  "bin": {
    "timps": "./sandeep-ai/main.js"
  },
  "preferGlobal": true,
  "files": [
    "sandeep-ai/",
    "docker-compose.yml",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "npm@10.9.4",
  "workspaces": [
    "packages/*",
    "apps/*",
    "timps-code",
    "timps-mcp",
    "docs"
  ],
  "description": "TIMPs - A persistent cognitive partner that remembers, evolves, and builds with its user",
  "main": "dist/main.js",
  "scripts": {
    "build": "turbo run build --filter=!@timps/mobile --filter=!@timps/docusaurus --filter=!@timps/docs --filter=!@timps/integration-base --filter=!@timps/plugin-sdk --filter=!@timps-plugin/git --filter=!@timps-plugin/shell --filter=!@timps/memory-dashboard --filter=!timps-code --filter=!timps-mcp",
    "test": "turbo run test --filter=!@timps/mobile --filter=!@timps/docusaurus --filter=!@timps/docs --filter=!@timps/integration-base --filter=!@timps/plugin-sdk --filter=!@timps-plugin/git --filter=!@timps-plugin/shell --filter=!@timps/memory-dashboard --filter=!timps-code --filter=!timps-mcp",
    "typecheck": "turbo run typecheck --filter=!@timps/mobile",
    "clean": "turbo run clean --filter=!@timps/mobile",
    "docs": "turbo run build --filter=@timps/docs",
    "dashboard": "turbo run dev --filter=@timps/memory-dashboard",
    "cli": "cd timps-code && npm run dev",
    "tui": "cd timps-code && npm run dev"
  },
  "keywords": [
    "ai",
    "agent",
    "memory",
    "llm",
    "gpt",
    "gemini",
    "ollama"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@qdrant/js-client-rest": "^1.9.0",
    "blessed": "^0.1.81",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "openai": "^4.63.0",
    "pg": "^8.12.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.12",
    "@types/blessed": "^0.1.21",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "@types/pg": "^8.11.8",
    "ts-node": "^10.9.2",
    "turbo": "^2.9.9",
    "typescript": "^5.5.0"
  }
}
